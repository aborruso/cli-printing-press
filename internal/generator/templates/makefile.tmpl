.PHONY: build test lint install clean

build:
	go build -o bin/{{.Name}}-pp-cli ./cmd/{{.Name}}-pp-cli

test:
	go test ./...

lint:
	golangci-lint run

install:
	go install ./cmd/{{.Name}}-pp-cli

clean:
	rm -rf bin/
{{- if .VisionSet.MCP}}

build-mcp:
	go build -o bin/{{.Name}}-pp-mcp ./cmd/{{.Name}}-pp-mcp

install-mcp:
	go install ./cmd/{{.Name}}-pp-mcp

build-all: build build-mcp
{{- end}}
